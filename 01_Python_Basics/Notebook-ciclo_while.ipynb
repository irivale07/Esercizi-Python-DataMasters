    "# Ciclo WHILE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "b70a0c42-3157-4a89-99c0-4cd95924c514",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "5\n",
      "6\n",

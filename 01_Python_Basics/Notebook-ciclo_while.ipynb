      "La variabile 'n' vale 10\n"
     ]
    }
   ],
   "source": [
    "n = 5\n",
    "\n",
    "while n < 10:\n",
    "    print(n)\n",
    "    n = n + 1\n",
    "\n",
    "print(\"La variabile 'n' vale\", n)"
   ]
